<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Workflow Primer — AI-TEC</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,400;0,600;0,700;0,900;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
:root {
  --navy:   #000066;
  --gold:   #FFC000;
  --purple: #6600FF;
  --green:  #33CC33;
  --teal:   #0B5563;
  --red:    #CC2200;
  --cream:  #F8F5EE;
  --dark:   #0A0A1A;
}
 
body {
  background: var(--cream);
  font-family: 'Barlow', sans-serif;
  min-height: 100vh;
}
 
.poster {
  max-width: 960px;
  margin: 0 auto;
  overflow: hidden;
}
 
/* ── HEADER BAND ── */
.header-band {
  background: var(--navy);
  padding: 28px 40px 20px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20px;
}
.header-eyebrow {
  font-family: 'Barlow', sans-serif;
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 6px;
}
.header-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.8rem, 6vw, 4.2rem);
  color: #fff;
  letter-spacing: 0.04em;
  line-height: 0.95;
}
.header-title span { color: var(--gold); }
.header-rule {
  font-family: 'Barlow', sans-serif;
  font-weight: 900;
  font-size: clamp(0.85rem, 2vw, 1.1rem);
  color: var(--green);
  text-align: right;
  max-width: 320px;
  line-height: 1.4;
}
.header-rule em {
  display: block;
  font-style: italic;
  font-weight: 400;
  color: rgba(255,255,255,0.65);
  font-size: 0.85em;
  margin-top: 4px;
}
 
/* ── THE MAGNIFIER STATEMENT ── */
.magnifier-band {
  background: var(--gold);
  padding: 14px 40px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.magnifier-icon {
  font-size: 2rem;
  flex-shrink: 0;
}
.magnifier-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.4rem, 3.5vw, 2rem);
  color: var(--navy);
  letter-spacing: 0.04em;
}
.magnifier-text span {
  color: var(--purple);
}
.magnifier-sub {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--navy);
  opacity: 0.7;
  margin-left: auto;
  text-align: right;
  max-width: 260px;
  line-height: 1.3;
}
 
/* ── PROBLEM PANEL ── */
.problem-panel {
  background: #1A0A2E;
  padding: 32px 40px;
  position: relative;
}
.problem-panel::before {
  content: 'THE PROBLEM';
  position: absolute;
  top: 18px;
  left: 40px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 0.8rem;
  letter-spacing: 0.25em;
  color: rgba(255,255,255,0.25);
}
.panel-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  color: #fff;
  letter-spacing: 0.04em;
  margin-top: 20px;
  margin-bottom: 24px;
  line-height: 1;
}
.panel-headline .accent { color: var(--red); }
 
.gigo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}
 
.gigo-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 20px 18px;
  position: relative;
  overflow: hidden;
}
.gigo-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--red);
}
.gigo-card.data::before { background: #FF6600; }
.gigo-card.prompt::before { background: #FF9900; }
 
.gigo-number {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 3rem;
  color: rgba(255,255,255,0.08);
  position: absolute;
  top: 8px;
  right: 14px;
  line-height: 1;
}
.gigo-icon { font-size: 1.8rem; margin-bottom: 10px; }
.gigo-label {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.1rem;
  color: var(--red);
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}
.gigo-card.data .gigo-label { color: #FF6600; }
.gigo-card.prompt .gigo-label { color: #FF9900; }
 
.gigo-problem {
  font-weight: 700;
  font-size: 0.95rem;
  color: #fff;
  margin-bottom: 8px;
  line-height: 1.3;
}
.gigo-result {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.4;
}
.gigo-result strong {
  color: var(--gold);
  font-weight: 700;
}
 
.problem-footer {
  background: rgba(204,34,0,0.15);
  border: 1px solid rgba(204,34,0,0.3);
  border-radius: 6px;
  padding: 12px 18px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.problem-footer-icon { font-size: 1.4rem; flex-shrink: 0; }
.problem-footer-text {
  font-size: 0.9rem;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
}
.problem-footer-text em {
  font-style: normal;
  color: var(--gold);
}
 
/* ── DIVIDER ARROW ── */
.divider {
  background: var(--gold);
  text-align: center;
  padding: 8px;
  font-size: 1.4rem;
  line-height: 1;
}
 
/* ── SOLUTION PANEL ── */
.solution-panel {
  background: var(--teal);
  padding: 32px 40px;
  position: relative;
}
.solution-panel::before {
  content: 'THE SOLUTION';
  position: absolute;
  top: 18px;
  left: 40px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 0.8rem;
  letter-spacing: 0.25em;
  color: rgba(255,255,255,0.25);
}
 
.solution-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  color: #fff;
  letter-spacing: 0.04em;
  margin-top: 20px;
  margin-bottom: 24px;
  line-height: 1;
}
.solution-headline .accent { color: var(--green); }
 
.solution-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}
 
.solution-card {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  padding: 20px 18px;
  position: relative;
  overflow: hidden;
}
.solution-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--green);
}
.solution-card.data::before { background: #00CCAA; }
.solution-card.prompt::before { background: var(--gold); }
 
.sol-icon { font-size: 1.8rem; margin-bottom: 10px; }
.sol-label {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.1rem;
  color: var(--green);
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}
.solution-card.data .sol-label { color: #00CCAA; }
.solution-card.prompt .sol-label { color: var(--gold); }
 
.sol-title {
  font-weight: 700;
  font-size: 0.95rem;
  color: #fff;
  margin-bottom: 8px;
  line-height: 1.3;
}
.sol-detail {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.6);
  line-height: 1.4;
}
.sol-detail strong {
  color: var(--gold);
  font-weight: 700;
}
 
/* ── RULES BAND ── */
.rules-band {
  background: var(--navy);
  padding: 24px 40px;
}
.rules-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.2rem;
  color: var(--gold);
  letter-spacing: 0.15em;
  margin-bottom: 16px;
}
.rules-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}
.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: rgba(255,255,255,0.05);
  border-radius: 6px;
  padding: 10px 14px;
  border-left: 3px solid var(--purple);
}
.rule-x {
  font-size: 1rem;
  flex-shrink: 0;
  margin-top: 1px;
}
.rule-text {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.8);
  line-height: 1.4;
  font-weight: 600;
}
.rule-text em {
  display: block;
  font-style: italic;
  font-weight: 400;
  color: rgba(255,255,255,0.45);
  margin-top: 2px;
}
 
/* ── VERSION 1 REMINDER ── */
.v1-band {
  background: var(--purple);
  padding: 16px 40px;
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 16px;
  align-items: center;
}
.v1-label {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.5rem;
  color: var(--gold);
  letter-spacing: 0.04em;
  line-height: 1;
}
.v1-text {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.9);
  line-height: 1.5;
}
.v1-text strong { color: var(--gold); }
 
/* ── FOOTER ── */
.poster-footer {
  background: var(--navy);
  border-top: 3px solid var(--gold);
  padding: 16px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.footer-cta {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1rem, 2.5vw, 1.4rem);
  color: #fff;
  letter-spacing: 0.05em;
}
.footer-cta span { color: var(--gold); }
.footer-brand {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.4);
  text-align: right;
  line-height: 1.5;
}
 
/* ── RESPONSIVE ── */
@media (max-width: 640px) {
  .header-band, .magnifier-band, .problem-panel,
  .solution-panel, .rules-band, .v1-band, .poster-footer {
    padding-left: 20px;
    padding-right: 20px;
  }
  .gigo-grid, .solution-grid { grid-template-columns: 1fr; }
  .rules-grid { grid-template-columns: 1fr; }
  .magnifier-sub { display: none; }
  .header-rule { display: none; }
  .v1-band { grid-template-columns: 1fr; }
  .poster-footer { flex-direction: column; align-items: flex-start; }
  .footer-brand { text-align: left; }
}
</style>
</head>
